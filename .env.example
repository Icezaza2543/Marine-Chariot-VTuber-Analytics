# X API v2 bearer token.
# Create it in the X Developer Console, then set it locally in .env.local
# and in Vercel Project Settings -> Environment Variables.
X_BEARER_TOKEN=

# Optional live YouTube analytics CSV source.
# Defaults to the published Marine Chariot Google Sheet when omitted.
VITE_MARINE_CSV_URL=

# Optional overrides used by scripts/fetch-x-data.mjs
X_USERNAME=MarineChariot
X_MAX_POSTS=100
X_MAX_PAGES=3
